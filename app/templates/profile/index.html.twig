{% extends 'base.html.twig' %}

{% block title %}Mon profil{% endblock %}

{% block body %}
<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <h1 class="mb-4">👤 Mon profil</h1>
        <p class="text-muted">{{ app.user.email }}</p>

        {# Enchères en cours #}
        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0">🔨 Mes enchères en cours</h5>
            </div>
            <div class="card-body">
                {% if offers|length > 0 %}
                    <table class="table table-dark table-hover">
                        <thead>
                            <tr>
                                <th>Objet</th>
                                <th>Mon offre</th>
                                <th>Statut</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for offer in offers %}
                                {% if offer['status'] == 'published' %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_item_show', {id: offer['itemId']}) }}">
                                            {{ offer['title'] }}
                                        </a>
                                    </td>
                                    <td>{{ offer['amount'] }} €</td>
                                    <td><span class="badge bg-success">En cours</span></td>
                                </tr>
                                {% endif %}
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-muted">Aucune enchère en cours.</p>
                {% endif %}
            </div>
        </div>

        {# Objets gagnés #}
        <div class="card">
            <div class="card-header">
                <h5 class="mb-0">🏆 Mes objets gagnés</h5>
            </div>
            <div class="card-body">
                {% if wonItems|length > 0 %}
                    <table class="table table-dark table-hover">
                        <thead>
                            <tr>
                                <th>Objet</th>
                                <th>Prix final</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in wonItems %}
                                <tr>
                                    <td>
                                        <a href="{{ path('app_item_show', {id: item['id']}) }}">
                                            {{ item['title'] }}
                                        </a>
                                    </td>
                                    <td>{{ item['finalPrice'] }} €</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-muted">Aucun objet gagné pour l'instant.</p>
                {% endif %}
            </div>
        </div>

    </div>
</div>
{% endblock %}
