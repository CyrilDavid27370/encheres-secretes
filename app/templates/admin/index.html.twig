{% extends 'base.html.twig' %}

{% block title %}Administration{% endblock %}

{% block body %}
<div class="d-flex justify-content-between mb-4">
    <h1>⚙️ Administration — Liste des objets</h1>
    <a href="{{ path('app_admin_item_form') }}" class="btn btn-success">➕ Ajouter un objet</a>
</div>

<table class="table table-dark table-hover">
    <thead>
        <tr>
            <th>Titre</th>
            <th>Prix de départ</th>
            <th>Statut</th>
            <th>Nombre d'enchères</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for row in items %}
            {% set item = row[0] %}
            {% set offerCount = row['offerCount'] %}
            <tr>
                <td>{{ item.title }}</td>
                <td>{{ item.startingPrice }} €</td>
                <td>
                    <span class="badge {{ item.status == 'published' ? 'bg-success' : (item.status == 'closed' ? 'bg-secondary' : 'bg-warning') }}">
                        {{ item.status == 'published' ? 'En cours' : (item.status == 'closed' ? 'Clôturé' : 'Non publié') }}
                    </span>
                </td>
                <td>{{ item.status == 'published' ? offerCount : '-' }}</td>
                <td>
                    <a href="{{ path('app_admin_item_show', {id: item.id}) }}" class="btn btn-sm btn-primary">Voir</a>
                    <a href="{{ path('app_admin_item_form', {id: item.id}) }}" class="btn btn-sm btn-warning">Modifier</a>
                    <form method="post" action="{{ path('app_admin_item_delete', {id: item.id}) }}" onsubmit="return confirm('Supprimer cet objet ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                        <button type="submit" class="btn btn-sm btn-danger">🗑️ Supprimer</button>
                    </form>
                </td>
            </tr>
        {% endfor %}
    </tbody>
</table>
{% endblock %}
