{% extends 'base.html.twig' %}

{% block title %}Liste des objets{% endblock %}

{% block body %}

<h1 class="mb-4 text-center">🏺 Objets aux enchères</h1>

{# Filtre par catégorie #}
<div class="mb-4 text-center">
    <a href="{{ path('app_home') }}" class="btn btn-sm {{ selectedCategory is null ? 'btn-light' : 'btn-outline-light' }} me-1">
        Toutes
    </a>
    {% for category in categories %}
        <a href="{{ path('app_home', {category: category.id}) }}"
        class="btn btn-sm {{ selectedCategory == category.id ? 'btn-light' : 'btn-outline-light' }} me-1">
            {{ category.name }}
        </a>
    {% endfor %}
</div>

{# Liste des objets #}
<div class="row row-cols-1 row-cols-md-3 g-4">
    {% for row in items %}
    {% set item = row[0] %}
    {% set offerCount = row['offerCount'] %}
    <div class="col">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">{{ item.title }}</h5>
                <p class="card-text text-muted">{{ item.description|slice(0, 80) }}...</p>
                <p class="card-text">
                    <strong>Prix de départ :</strong> {{ item.startingPrice }} €
                </p>
                <span class="badge {{ item.status == 'published' ? 'bg-success' : 'bg-secondary' }}">
                    {{ item.status == 'published' ? 'En cours' : 'Clôturé' }}
                </span>
                {% if item.status == 'published' %}
                    <small class="text-muted ms-2">🔨 {{ offerCount }} enchère(s)</small>
                {% endif %}
            </div>
            <div class="card-footer">
                <a href="{{ path('app_item_show', {id: item.id}) }}" class="btn btn-primary btn-sm">
                    Voir le détail
                </a>
            </div>
        </div>
    </div>
{% else %}
    <p class="text-muted">Aucun objet disponible.</p>
{% endfor %}
</div>

{% endblock %}
