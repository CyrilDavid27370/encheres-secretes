{% extends 'base.html.twig' %}

{% block title %}{{ item.title }}{% endblock %}

{% block body %}

<div class="row justify-content-center mt-5">
    <div class="col-md-8">
        <a href="{{ path('app_home') }}" class="btn btn-outline-light mb-3">← Retour</a>

        <div class="card">
            <div class="card-header">
                <h2>{{ item.title }}</h2>
            </div>
            <div class="card-body">
                <p>{{ item.description }}</p>

                <p>
                    <strong>Prix de départ :</strong> {{ item.startingPrice }} €
                </p>

                <p>
                    <strong>Statut :</strong>
                    <span class="badge {{ item.status == 'published' ? 'bg-success' : 'bg-secondary' }}">
                        {{ item.status == 'published' ? 'En cours' : 'Clôturé' }}
                    </span>
                </p>

                <p>
                    <strong>Catégories :</strong>
                    {% for category in item.categories %}
                        <span class="badge bg-info">{{ category.name }}</span>
                    {% endfor %}
                </p>

                {% if item.status == 'closed' and item.winner %}
                    <div class="alert alert-success">
                        🏆 <strong>Gagnant :</strong> {{ item.winner.email }}
                    </div>
                {% endif %}
            {% if app.user and item.status == 'published' %}
                    <hr>
                    {% if form %}
                        <h5>💰 Placer une enchère</h5>
                        {{ form_start(form) }}
                            <div class="mb-3">
                                {{ form_label(form.amount) }}
                                {{ form_widget(form.amount) }}
                                {{ form_errors(form.amount) }}
                            </div>
                            <button type="submit" class="btn btn-success w-100">Confirmer mon enchère</button>
                        {{ form_end(form) }}
                    {% else %}
                        <div class="alert alert-info">Vous avez déjà placé une enchère sur cet objet.</div>
                    {% endif %}
                {% elseif not app.user %}
                    <hr>
                    <p class="text-muted">
                        <a href="{{ path('app_login') }}">Connectez-vous</a> pour placer une enchère.
                    </p>
                {% endif %}
            </div>
        </div>
    </div>
</div>

{% endblock %}
